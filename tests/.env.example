# Copy to tests/.env and fill in before running integration tests.
# tests/.env is gitignored. This file is committed as a template only —
# it must never contain real hostnames, IPs, or credentials.

# ── OPNsense / Kea box ────────────────────────────────────────────────────────
OPNSENSE_HOST=<your-opnsense-hostname-or-ip>
OPNSENSE_SSH_USER=<ssh-user>
OPNSENSE_SSH_PASS=<ssh-password>
OPNSENSE_API_KEY=<api-key-id>
OPNSENSE_API_SECRET=<api-key-secret>

# ── DHCP client box ───────────────────────────────────────────────────────────
# A machine that gets a DHCP lease from the OPNsense box.
# Used by test_e2e_dhcp_flow.py; all other integration tests skip if unset.
DHCPCLIENT_HOST=<dhcp-client-hostname-or-ip>
DHCPCLIENT_SSH_USER=<ssh-user>
DHCPCLIENT_SSH_PASS=<ssh-password>
DHCPCLIENT_LAN_IF=<dhcp-interface-name-on-client>
# Short hostname (no domain) as sent in DHCP requests, e.g. myhost
DHCPCLIENT_HOSTNAME=<client-hostname-without-domain>

# ── Plugin build tree on the OPNsense box ────────────────────────────────────
# Where the opnsense/plugins tree is checked out.
PLUGIN_DIR=/usr/plugins/net/kea-unbound

# ── Test data allocation ──────────────────────────────────────────────────────
# IP range used for injected test leases / reservations.
# Must be in the DHCP subnet but OUTSIDE the DHCP pool to avoid collisions.
# Default (if unset): 192.168.99.x — safe for any network when using the
# Kea admin API (out-of-pool IPs are accepted by lease4-add).
TEST_IP_PREFIX=<ip-prefix-ending-in-dot  e.g. 192.168.1.>
TEST_IP_START=<first-octet-of-test-range  e.g. 201>
